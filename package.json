{
  "name": "crm-to-web-flow-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Sanitized CRM export to website automation demo.",
  "scripts": {
    "crm:sync": "python3 scripts/sync_from_mock_crm.py",
    "crm:validate": "python3 scripts/sync_from_mock_crm.py --check && python3 scripts/validate_ai_summary.py",
    "crm:mcp": "python3 scripts/mock_crm_mcp_server.py",
    "crm:win-local": "python3 scripts/mock_crm_update.py --opportunity OPP-2026-002 --stage \"Closed Won\" --probability 1 --amount 1500000 && npm run generate",
    "crm:win-routine": "python3 scripts/mock_crm_update.py --opportunity OPP-2026-002 --stage \"Closed Won\" --probability 1 --amount 1500000 --commit --push --release",
    "crm:win": "npm run crm:win-routine",
    "crm:reset": "python3 scripts/reset_demo_baseline.py --commit --push",
    "crm:resume": "python3 scripts/mock_crm_update.py --release-only --push --release",
    "crm:release": "python3 scripts/mock_crm_update.py --release-only --release",
    "demo:change": "npm run crm:win-routine",
    "excel:refresh": "python3 scripts/ingest_crm_export.py data/crm-export-june-2026.xlsx",
    "excel:generate": "npm run excel:refresh && npm run ai:local",
    "excel:validate": "python3 scripts/ingest_crm_export.py data/crm-export-june-2026.xlsx --check && python3 scripts/validate_ai_summary.py",
    "refresh:data": "npm run crm:sync",
    "ai:local": "python3 scripts/simulate_ai_summary.py",
    "generate": "npm run crm:sync && npm run ai:local",
    "validate": "npm run crm:validate",
    "watch:excel": "python3 scripts/watch_excel_and_push.py",
    "watch:routine": "python3 scripts/watch_excel_and_push.py --publish-release",
    "push:excel": "python3 scripts/watch_excel_and_push.py --once",
    "push:routine": "python3 scripts/watch_excel_and_push.py --once --publish-release",
    "serve": "python3 -m http.server 4173 -d site"
  }
}
